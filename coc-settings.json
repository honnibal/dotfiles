{
  "coc.preferences.formatOnSaveFiletypes": ["python", "yaml", "json"],
  "pyright.enable": true,
  "python.linting.flake8Enabled": true,
  "python.formatting.provider": "black",
  "coc.source.around.enable": false,
  "coc.source.buffer.enable": false,
  "coc.source.file.enable": false,
  "coc.source.floaterm.enable": false,
  "coc.source.pyright.enable": false,
  "pyright.completion.snippetSupport": true,
  "suggest.autoTrigger": "none",
  "diagnostic.enable": true,
  "suggest.timeout": 5000,
  "python.linting.flake8Args": ["--max-line-length=88"],
  "languageserver": {
	"terraform": {
	  "command": "terraform-ls",
	  "args": ["serve"],
	  "filetypes": [
		"terraform",
		"tf"
	  ],
	  "initializationOptions": {},
	  "settings": {}
	}
  }
}
